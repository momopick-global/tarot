# 프로젝트 루트만 (예: https://xxxx.supabase.co) — /auth/v1/callback 을 붙이면 OAuth가 깨집니다
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# 사이트 절대 URL (운영 도메인 예시)
NEXT_PUBLIC_SITE_URL=https://yourtarot.cc

# robots.txt의 Sitemap URL 호스트 (비우면 https://yourtarot.cc — apex)
# NEXT_PUBLIC_ROBOTS_SITEMAP_ORIGIN=https://yourtarot.cc

# Google Tag Manager 컨테이너 ID (비우면 코드 기본값 GTM-5D6VW4MD 사용)
# NEXT_PUBLIC_GTM_ID=GTM-5D6VW4MD

# 카카오 공유는 웹 공유 링크를 사용합니다 (앱 키 불필요)

